@page
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer localizer
@model EnableAuthenticatorModel
@{
    ViewData["Title"] = localizer ["Title"];
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />
<h3>@ViewData["Title"]</h3>
<div>
    <p>@localizer["ConfigureExplanation00"]</p>
    <ol class="list">
        <li>
            <p>
                @localizer["ConfigureStep01-01"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825072">Android</a> @localizer["ConfigureStep01-02"]
                <a href="https://go.microsoft.com/fwlink/?Linkid=825073">iOS</a> @localizer["ConfigureStep01-03"]
                @localizer["ConfigureStep01-04"]
                <a href="https://play.google.com/store/apps/details?id=com.google.android.apps.authenticator2&amp;hl=en">Android</a> @localizer["ConfigureStep01-02"]
                <a href="https://itunes.apple.com/us/app/google-authenticator/id388497605?mt=8">iOS</a>.
            </p>
        </li>
        <li>
            <p>@localizer["ConfigureStep02-01"] <kbd>@Model.SharedKey</kbd> @localizer["ConfigureStep02-02"]</p>
            
            <div id="qrCode"></div>
            <div id="qrCodeData" data-url="@Model.AuthenticatorUri"></div>
        </li>
        <li>
            <p>
                @localizer["ConfigureStep03-01"]
                @localizer["ConfigureStep03-02"]
            </p>
            <div class="row">
                <div class="col-md-6">
                    <form id="send-code" method="post">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Code" class="form-control" autocomplete="off" placeholder="@localizer["CodeInputPlaceholder"]"/>
                            <label asp-for="Input.Code" class="control-label form-label">@localizer["CodeInputLabel"]</label>
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>
                        <button type="submit" class="w-100 btn btn-lg btn-primary">@localizer["CodeVerifyButton"]</button>
                        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
                    </form>
                </div>
            </div>
        </li>
    </ol>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial");
    <script type="text/javascript" src="~/lib/qrcodejs/qrcode.js"></script>
    <script type="text/javascript" src="~/js/qr.js"></script>
}
